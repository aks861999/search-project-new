# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
# Only needed when security plugin is enabled:
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=Admin@1234!

# ── Index ─────────────────────────────────────────────────────────────────────
INDEX_NAME=products

# ── Embedding model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
BATCH_SIZE=128

# ── HuggingFace dataset (ingestion only) ──────────────────────────────────────
HF_DATASET=McAuley-Lab/Amazon-Reviews-2023
HF_DATASET_CONFIG=raw_meta_All_Beauty
CHUNK_SIZE=500

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# ── Google Generative AI (optional — NL query chain) ─────────────────────────
# If unset, the stub parser is used instead of Gemini.
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="AIzaSyBwVVrvy_ML0-Z_OgsJaKqzbMIiWzXfc_g"

# LLM model name (used only when GOOGLE_API_KEY is set)
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.0

# ── API ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
API_WORKERS=1

# ── Search tuning ─────────────────────────────────────────────────────────────
DEFAULT_SIZE=10
KNN_K=100
HYBRID_BM25_WEIGHT=0.4
HYBRID_KNN_WEIGHT=0.6
